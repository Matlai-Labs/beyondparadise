# Beyond Paradise — Environment Variables
# Copy this file to .env and fill in your real keys
# NEVER commit .env — it contains secrets

# Gemini API key (primary for grounded web research)
# Get from: https://aistudio.google.com/apikey
# Gemini grounding is FREE under ~1,500 calls/day. Beyond that: $35/1k.
# The spend guard caps at 200 calls/day by default.
GEMINI_API_KEY=AIza...

# Grounded research fallback (paid; use when Gemini is blocked/rate-limited)
# Best citation quality, but costs money, so the same spend guard caps calls.
PERPLEXITY_API_KEY=pplx-...

# Cheap JSON structuring fallbacks after local Ollama/Gemini
# OpenRouter reaches Gemini Flash-Lite + DeepSeek with one key.
OPENROUTER_API_KEY=sk-or-v1-...

# Direct cheap JSON/extraction provider.
DEEPSEEK_API_KEY=sk-...

# Structured-output fallback; also useful for voice/transcription elsewhere.
OPENAI_API_KEY=sk-...

# Final JSON fallback / private-safe floor for hard structuring failures.
ANTHROPIC_API_KEY=sk-ant-api03-...
# Older Matlai projects use this alias for Anthropic:
CLAUDE_API_KEY=sk-ant-api03-...

# Search API keys for future free-search cascade work.
# Tavily is preferred free search; Brave is available but generally not first choice.
TAVILY_API_KEY=tvly-...
BRAVE_API_KEY=BSA_...
# Older PadelRevive projects use this alias:
BRAVE_SEARCH_API_KEY=BSA_...

# Optional local free structuring. If Ollama is running, set this to 1.
# RESEARCH_USE_OLLAMA=1
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:8b

# Provider controls
# RESEARCH_SKIP_GEMINI=0
# RESEARCH_USE_SEARCH_FALLBACK=0
# PERPLEXITY_MODEL=sonar
# GEMINI_MODEL=gemini-2.5-flash
# OPENROUTER_STRUCT_MODELS=google/gemini-2.5-flash-lite,deepseek/deepseek-chat
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_STRUCT_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Research spend caps (optional — defaults are conservative)
# RESEARCH_MAX_CALLS_DAY=200
# RESEARCH_MAX_CALLS_RUN=30
