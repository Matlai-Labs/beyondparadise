---
import Base from './Base.astro';
import AuthorBlock from '../components/AuthorBlock.astro';
import FAQ from '../components/FAQ.astro';

interface Props {
  title: string;
  description: string;
  permalink: string;
  heroImage: string;
  heroAlt: string;
  author: 'tim' | 'kim';
  lastUpdated: string;
  visitDate?: string;
  authorContext?: string;
  faq?: { q: string; a: string }[];
  schemaType?: 'Article' | 'Review';
  schemaExtra?: Record<string, unknown>;
}

const {
  title, description, permalink, heroImage, heroAlt,
  author, lastUpdated, visitDate, authorContext,
  faq, schemaType = 'Article', schemaExtra = {},
} = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  headline: title,
  description,
  url: `https://beyondparadise.com${permalink}`,
  image: heroImage,
  dateModified: lastUpdated,
  author: {
    '@type': 'Person',
    name: author === 'tim' ? 'Tim Hennig' : 'Kim',
    url: author === 'tim' ? 'https://beyondparadise.com/about/' : 'https://beyondparadise.com/about/kim/',
    sameAs: author === 'tim' ? ['https://www.wikidata.org/wiki/Q140307013'] : [],
  },
  publisher: {
    '@type': 'Organization',
    name: 'Beyond Paradise',
    url: 'https://beyondparadise.com',
  },
  ...schemaExtra,
};
---
<Base title={title} description={description} permalink={permalink}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <article class="article">
    <!-- Hero -->
    <div class="article__hero">
      <img src={heroImage} alt={heroAlt} class="article__hero-img" width="1440" height="600" />
      <div class="article__hero-overlay"></div>
      <div class="article__hero-content container">
        <h1 class="article__title display-l">{title}</h1>
        <p class="article__meta">
          By <span style="color:var(--gold)">{author === 'tim' ? 'Tim Hennig' : 'Kim'}</span>
          {visitDate && <> &nbsp;·&nbsp; Visited {visitDate}</>}
          &nbsp;·&nbsp; Updated <time datetime={lastUpdated}>{lastUpdated}</time>
        </p>
      </div>
    </div>

    <!-- Body -->
    <div class="article__body container">
      <div class="article__content prose">
        <slot />
      </div>

      {faq && faq.length > 0 && <FAQ items={faq} />}

      <AuthorBlock author={author} visitDate={visitDate} context={authorContext} />
    </div>
  </article>
</Base>

<style>
.article__hero {
  position: relative;
  height: 520px;
  overflow: hidden;
  margin-top: -72px;
}
.article__hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.article__hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(9,9,11,0.92) 0%, rgba(9,9,11,0.4) 50%, rgba(9,9,11,0.15) 100%);
}
.article__hero-content {
  position: absolute;
  bottom: 48px;
  left: 0;
  right: 0;
}
.article__title {
  max-width: 800px;
  margin-bottom: 12px;
}
.article__meta {
  font-size: 13px;
  color: var(--cream-65);
  letter-spacing: 0.04em;
}
.article__body {
  padding-top: 64px;
  padding-bottom: 96px;
  max-width: 800px;
}

/* Prose styles */
.prose { color: var(--cream-65); line-height: 1.8; font-size: 16px; }
.prose h2 {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(22px, 3vw, 28px);
  font-weight: 400;
  color: var(--cream);
  margin: 48px 0 16px;
  padding-top: 48px;
  border-top: 1px solid var(--glass-b);
}
.prose h3 {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 20px;
  font-weight: 400;
  color: var(--cream);
  margin: 32px 0 12px;
}
.prose p { margin-bottom: 20px; }
.prose strong { color: var(--cream); font-weight: 600; }
.prose em { font-style: italic; color: var(--cream); }
.prose ul, .prose ol { padding-left: 20px; margin-bottom: 20px; }
.prose li { margin-bottom: 8px; }
.prose a { color: var(--gold); text-decoration: underline; text-decoration-color: rgba(201,169,110,0.4); }
.prose a:hover { text-decoration-color: var(--gold); }
.prose blockquote {
  border-left: 3px solid var(--gold);
  padding: 16px 20px;
  margin: 32px 0;
  background: rgba(201,169,110,0.05);
  border-radius: 0 8px 8px 0;
  font-style: italic;
  color: var(--cream);
  font-size: 17px;
  line-height: 1.7;
}
.prose table { width: 100%; border-collapse: collapse; margin: 32px 0; font-size: 14px; }
.prose th {
  text-align: left;
  padding: 10px 14px;
  border-bottom: 1px solid var(--glass-b);
  color: var(--gold);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.prose td { padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,0.04); color: var(--cream-65); }
.prose tr:hover td { background: rgba(255,255,255,0.02); }

@media (max-width: 700px) {
  .article__hero { height: 360px; }
  .article__hero-content { bottom: 24px; }
  .article__body { padding-top: 40px; }
}
</style>
