---
const criteria = [
  'Wildlife quality & guide expertise',
  'Accommodation & room size',
  'Food & beverage',
  'Conservation commitment',
  'Value at price point',
  'Location & views',
  'Privacy & exclusivity',
  'Service quality',
  'Activities range',
  'Environmental impact',
  'Connectivity & logistics',
  'Child & family policy',
];
---
<section id="tim-score" class="section score-section" aria-label="The Tim Score">
  <div class="container score-grid">
    <div class="score-left reveal">
      <p class="label">THE TIM SCORE</p>
      <h2 class="display-m" style="margin-top:12px;margin-bottom:24px;">A Rating Built on<br/>Actual Stays</h2>
      <p class="body-l" style="color:var(--cream-65);margin-bottom:32px;">12 criteria, weighted by what sophisticated travelers actually care about. No press trips. No hosted stays. Tim and Kim pay their own way, every time.</p>
      <div class="score-criteria reveal reveal-delay-1">
        {criteria.map((c, i) => (
          <div class="score-criterion">
            <span class="score-criterion__num">{String(i+1).padStart(2,'0')}</span>
            <span class="score-criterion__text">{c}</span>
          </div>
        ))}
      </div>
      <a href="/about/tim-score/" class="btn btn-glass" style="margin-top:32px;">See Full Methodology</a>
    </div>

    <div class="score-right">
      <div class="score-note reveal reveal-delay-1" style="margin-top:0;">
        <p class="body-l" style="color:var(--cream-65);">No lodge has been scored yet — a Tim Score only exists after a paid, unhosted stay. The first scored reviews are in progress now.</p>
      </div>
      <div class="score-note reveal reveal-delay-3">
        <p class="meta" style="color:var(--cream-38);">Tim Score 90+ = exceptional. 85–89 = excellent. 80–84 = very good. Below 80 = not recommended.</p>
      </div>
    </div>
  </div>
</section>

<style>
.score-section {
  background: linear-gradient(135deg, var(--s1) 0%, #1A1208 100%);
  padding: 100px 0;
}
.score-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}
.score-criteria {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.score-criterion {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 10px 0;
  border-bottom: 1px solid var(--glass-sub);
}
.score-criterion__num { font-size: 11px; color: var(--gold); font-weight: 600; min-width: 28px; }
.score-criterion__text { font-size: 14px; color: var(--cream-65); }
.score-note { margin-top: 20px; padding: 16px; border-radius: 12px; background: var(--glass); border: 1px solid var(--glass-sub); }

@media (max-width: 900px) {
  .score-grid { grid-template-columns: 1fr; gap: 48px; }
}
</style>
